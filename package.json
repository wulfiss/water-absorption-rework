		"@smui/paper": "^8.0.3",
		"@smui/radio": "^8.0.3",
		"@smui/select": "^8.0.3",
		"@smui/textfield": "^8.0.3",
		"@smui/top-app-bar": "^8.0.3",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.5.27",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
